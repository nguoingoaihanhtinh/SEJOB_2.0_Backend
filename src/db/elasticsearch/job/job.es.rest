###

### =====================================
### 4. UPDATE JOB
### =====================================
POST {{host}}/jobs/_update/1
Content-Type: application/json

{
  "doc": {
    "title": "Senior Nodejs Backend Developer",
    "salary_max": 3000
  }
}

###

### =====================================
### 5. DELETE JOB
### =====================================
DELETE {{host}}/jobs/_doc/1

###

### =====================================
### 6. SEARCH JOBS (BM25)
### =====================================
GET {{host}}/jobs/_search
Content-Type: application/json

{
  "query": {
    "multi_match": {
      "query": "nodejs backend api",
      "fields": ["title", "description", "skills"]
    }
  }
}

###

### =====================================
### 7. SEARCH WITH BOOST
### =====================================
GET {{host}}/jobs/_search
Content-Type: application/json

{
  "query": {
    "multi_match": {
      "query": "nodejs backend",
      "fields": [
        "title^3",
        "skills^2",
        "description"
      ]
    }
  }
}

###

### =====================================
### 8. FILTER + SEARCH (REAL WORLD)
### =====================================
GET {{host}}/jobs/_search
Content-Type: application/json

{
  "query": {
    "bool": {
      "must": {
        "multi_match": {
          "query": "backend nodejs",
          "fields": ["title^3", "description", "skills"]
        }
      },
      "filter": [
        { "term": { "location": "HCM" } },
        { "term": { "is_remote": true } }
      ]
    }
  }
}